        {
          "info": {
            "name": "Spring Boot Get logger level",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "http://localhost:8080/actuator/loggers/:name",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Spring Boot Get logger level"
        },
        {
          "info": {
            "name": "Spring Boot Set logger level at runtime",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "http://localhost:8080/actuator/loggers/:name",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Spring Boot Set logger level at runtime"
        }
