        {
          "info": {
            "name": "Spring Boot Evict specific cache",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "http://localhost:8080/actuator/caches/:cacheName",
            "params": [
              {
                "name": "cacheName",
                "value": "",
                "type": "path"
              }
            ]
